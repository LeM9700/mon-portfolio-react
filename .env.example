# ============================================================
# BACKEND (server.js — Render.com en prod, local en dev)
# ============================================================

# PostgreSQL connection string
# Local    : postgresql://user:password@localhost:5432/portfolio
# Neon.tech (gratuit) : postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/portfolio?sslmode=require
DATABASE_URL="postgresql://username:password@localhost:5432/portfolio?schema=public"

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Port du serveur (Render le definit automatiquement)
PORT=3001
NODE_ENV=development

# Cle secrete pour /api/leads (POST creation + GET admin)
# Generer : openssl rand -hex 32
API_SECRET="your-secure-random-secret-here"

# ============================================================
# FRONTEND (Vite — buildte par Netlify)
# ============================================================

# Meme valeur que API_SECRET ci-dessus (envoye en header X-API-Secret)
VITE_API_SECRET="your-secure-random-secret-here"

# Laisser vide en production (le proxy Netlify gere /api/* -> Render)
# Definir uniquement en dev local pour cibler un backend distant
# VITE_API_URL=
